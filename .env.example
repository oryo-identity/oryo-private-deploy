# Copy this file to .env and fill in. .env is gitignored.
# Used by scripts/verify.sh (the preflight) — it reads these to verify your
# prerequisites (see docs/prereqs.md). verify.sh creates nothing in your AWS
# account.

# AWS — for the preflight checks
AWS_PROFILE=<your-aws-profile>   # SSO profile with access to the target account
AWS_REGION=<your-region>         # region your EKS cluster lives in, e.g. us-east-1
ACCOUNT_ID=<your-account-id>     # target AWS account ID (must match the profile)

# EKS
CLUSTER_NAME=<your-cluster-name> # name of your EKS cluster
NAMESPACE=oryo                   # k8s namespace you'll install into

# Domain — your domain in the same AWS account's Route 53 hosted zone.
# Used downstream to build the ACM cert + ingress hosts; also handy as a
# single source of truth referenced by values.custom.yaml.
DOMAIN=<your-domain>             # e.g. example.com (no scheme, no wildcard)

# Resources you created per docs/prereqs.md (verify.sh verifies these)
BUCKET_NAME=<your-s3-bucket>     # the object-storage bucket you created (§1)
# ROLE_NAME=OryoWorkloadRole     # IAM role you created (§2); override if you named it differently

# ───────────────────────────────────────────────────────────────────────────
# Only needed if you run `./scripts/verify.sh --bootstrap-secrets`
# (otherwise create the k8s Secrets yourself — see docs/runbook.md).
# ───────────────────────────────────────────────────────────────────────────

# RDS master creds — go into the oryo-db-admin secret, used once by dbInit to
# create the per-service Postgres roles + schema. The target database must
# already exist (default `postgres` works).
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=               # RDS master password

# Per-service Postgres role passwords + session-cookie HMAC key.
# Leave unset on first install — --bootstrap-secrets will generate them and
# print the values so you can save them here. Setting them makes future
# reinstalls against the same RDS idempotent: dbInit's role passwords stay
# aligned with the k8s Secrets across `helm uninstall` / `kubectl delete ns`.
# SESSION_SECRET=
# DASHBOARD_USER_PASSWORD=
# GATEWAY_USER_PASSWORD=
# WORKER_USER_PASSWORD=

# Resend API key — required. The dashboard emails login codes via Resend
# (https://resend.com). Use your own Resend API key, or ask the Oryo team
# to provide one for your install.
RESEND_API_KEY=                  # e.g. re_XXXXXXXXXXXXXXXX
