# Copy this file to .env and fill in. .env is gitignored.

# AWS
AWS_PROFILE=sandbox              # SSO profile name with admin in the target account
AWS_REGION=us-east-2             # region your EKS cluster lives in
ACCOUNT_ID=221759618824          # target AWS account ID (must match the SSO profile)

# EKS
CLUSTER_NAME=cluster-pd-1        # name of your EKS cluster
NAMESPACE=oryo                   # k8s namespace to deploy into

# Storage
BUCKET_NAME=oryo-objects-221759618824-us-east-2   # S3 bucket for object storage (must be globally unique)

# RDS — superuser creds are written to a k8s Secret (oryo-db-admin) and used
# only by the one-time dbInit hook. setup.sh also uses them to create the
# database if it doesn't exist (workaround pending dbInit fix).
DB_HOST=                          # RDS endpoint, e.g. db-x.abc.us-east-2.rds.amazonaws.com
DB_NAME=oryo                      # target database — must match global.db.database in values.yaml
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=                # RDS master password

# Optional overrides — leave blank to use defaults
# POLICY_NAME=OryoWorkloadPolicy
# ROLE_NAME=OryoWorkloadRole
# SERVICE_ACCOUNT=oryo-platform-workload
