# Copy this file to .env and fill in. .env is gitignored.

# AWS
AWS_PROFILE=<your-aws-profile>   # SSO profile name with admin in the target account
AWS_REGION=<your-region>         # region your EKS cluster lives in, e.g. us-east-1
ACCOUNT_ID=<your-account-id>     # target AWS account ID (must match the SSO profile)

# EKS
CLUSTER_NAME=<your-cluster-name> # name of your EKS cluster
NAMESPACE=oryo                   # k8s namespace to deploy into

# Storage
BUCKET_NAME=<globally-unique-bucket-name>   # S3 bucket for object storage, e.g. oryo-objects-<acct>-<region>

# RDS superuser creds — written to a k8s Secret (oryo-db-admin) and used only
# by the one-time dbInit hook to create per-service Postgres roles + schema.
# The target database itself must already exist in your RDS (use the default
# `postgres` database, or create one yourself before installing).
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=                # RDS master password

# Email — optional. If set, login codes will be emailed via Resend
# (https://resend.com — free tier available). If unset, login codes are
# generated but never delivered and you'll have to SQL the login_events
# table to read them. setup.sh creates the k8s secret only if this is set.
# SMTP / SES support is in flight.
RESEND_API_KEY=                   # e.g. re_XXXXXXXXXXXXXXXX

# Optional overrides — leave blank to use defaults
# POLICY_NAME=OryoWorkloadPolicy
# ROLE_NAME=OryoWorkloadRole
# SERVICE_ACCOUNT=oryo-platform-workload
